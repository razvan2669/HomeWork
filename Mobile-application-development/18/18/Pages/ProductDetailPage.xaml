<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:_18.ViewModels"
             x:Class="_18.Pages.ProductDetailPage"
             x:DataType="vm:ProductDetailViewModel"
             Title="Товар"
             BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray950}}">

    <ScrollView>
        <Grid>
            <!-- Контент товара - виден когда Product загружен -->
            <VerticalStackLayout Padding="20" Spacing="20" IsVisible="{Binding IsProductLoaded}">
                <Border Stroke="{StaticResource Primary}"
                        StrokeThickness="2"
                        Padding="24"
                        BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}"
                        StrokeShape="RoundRectangle 20">
                    <Border.Shadow>
                        <Shadow Brush="{StaticResource Gray400}" Offset="0,6" Radius="16" Opacity="0.15" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="16">
                        <Label Text="{Binding Product.ImageUrl}" 
                               FontSize="80" 
                               HorizontalOptions="Center" />
                        <Label Text="{Binding Product.Name}" 
                               FontSize="24" FontAttributes="Bold"
                               HorizontalTextAlignment="Center" />
                        <Label Text="{Binding Product.Description}" 
                               FontSize="15"
                               TextColor="{StaticResource Gray500}"
                               LineBreakMode="WordWrap" />
                        <Label Text="{Binding Product.FormattedPrice}" 
                               FontSize="28" FontAttributes="Bold"
                               TextColor="{StaticResource Accent}"
                               HorizontalOptions="Center" />
                        <Label Text="{Binding Product.Category, StringFormat='Категория: {0}'}" 
                               FontSize="14"
                               TextColor="{StaticResource Gray400}"
                               HorizontalOptions="Center" />
                        <Label Text="{Binding StockStatusText}" 
                               FontSize="14"
                               TextColor="{StaticResource Accent}"
                               HorizontalOptions="Center" />

                        <HorizontalStackLayout HorizontalOptions="Center" Spacing="16">
                            <Button Text="−" 
                                    Command="{Binding DecreaseQuantityCommand}"
                                    WidthRequest="48" HeightRequest="48"
                                    FontSize="20"
                                    BackgroundColor="{StaticResource Gray200}"
                                    TextColor="{StaticResource Black}" />
                            <Label Text="{Binding Quantity}" 
                                   FontSize="20" FontAttributes="Bold"
                                   VerticalOptions="Center"
                                   WidthRequest="40" HorizontalTextAlignment="Center" />
                            <Button Text="+" 
                                    Command="{Binding IncreaseQuantityCommand}"
                                    WidthRequest="48" HeightRequest="48"
                                    FontSize="20"
                                    BackgroundColor="{StaticResource Primary}"
                                    TextColor="White" />
                        </HorizontalStackLayout>

                        <Button Text="Добавить в корзину"
                                Command="{Binding AddToCartAsyncCommand}"
                                BackgroundColor="{StaticResource Accent}"
                                TextColor="White"
                                FontSize="18" FontAttributes="Bold"
                                HeightRequest="52"
                                CornerRadius="12" />

                        <Label Text="{Binding StatusMessage}"
                               TextColor="{StaticResource Accent}"
                               FontSize="14"
                               HorizontalOptions="Center"
                               IsVisible="{Binding HasStatusMessage}" />
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>

            <!-- Индикатор загрузки -->
            <ActivityIndicator IsRunning="{Binding IsLoading}"
                               IsVisible="{Binding IsLoading}"
                               VerticalOptions="Center"
                               HorizontalOptions="Center"
                               Color="{StaticResource Primary}"
                               HeightRequest="60" WidthRequest="60" />
        </Grid>
    </ScrollView>
</ContentPage>
