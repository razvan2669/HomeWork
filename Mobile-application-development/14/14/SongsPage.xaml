<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="_14.SongsPage"
             Title="Песни">

    <Grid RowDefinitions="Auto,*" Padding="20">
        <VerticalStackLayout Grid.Row="0" Spacing="10">
            <Label Text="Список песен" FontSize="Title" FontAttributes="Bold" />
            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <Button x:Name="BtnAddSong" Text="Добавить песню" Clicked="OnAddSongClicked" />
                <Button x:Name="BtnRemoveSong" Grid.Column="1" Text="Удалить выбранную" Clicked="OnRemoveSongClicked" />
            </Grid>
        </VerticalStackLayout>

        <Grid Grid.Row="1" ColumnDefinitions="*,*" ColumnSpacing="15">
            <VerticalStackLayout Spacing="8">
                <Label Text="Песни:" FontAttributes="Bold" />
                <CollectionView x:Name="SongsList"
                                SelectionMode="Single"
                                SelectionChanged="OnSongSelected">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="10" Margin="0,4" Stroke="Gray" StrokeThickness="1">
                                <Label Text="{Binding DisplayText}" LineBreakMode="WordWrap" />
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>

            <VerticalStackLayout Spacing="8">
                <Label Text="Информация о песне:" FontAttributes="Bold" />
                <ScrollView>
                    <Label x:Name="LblSongInfo"
                           Text="Выберите песню из списка"
                           LineBreakMode="WordWrap"
                           Padding="8" />
                </ScrollView>
            </VerticalStackLayout>
        </Grid>
    </Grid>
</ContentPage>
