<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="_19.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:pages="clr-namespace:_19.Pages"
    Title="Интернет-магазин">

    <TabBar>
        <Tab Title="Число" Icon="dotnet_bot.png">
            <ShellContent
                ContentTemplate="{DataTemplate pages:NumberReversePage}"
                Route="NumberReverse" />
        </Tab>
        <Tab Title="Классы" Icon="dotnet_bot.png">
            <ShellContent
                ContentTemplate="{DataTemplate pages:StoreClassesPage}"
                Route="StoreClasses" />
        </Tab>
        <Tab Title="Отображение" Icon="dotnet_bot.png">
            <ShellContent
                ContentTemplate="{DataTemplate pages:ProductDisplayPage}"
                Route="ProductDisplay" />
        </Tab>
        <Tab Title="Магазин" Icon="dotnet_bot.png">
            <ShellContent
                ContentTemplate="{DataTemplate pages:StorePage}"
                Route="Store" />
        </Tab>
        <Tab Title="Товар" Icon="dotnet_bot.png">
            <ShellContent
                ContentTemplate="{DataTemplate pages:ProductDetailPage}"
                Route="ProductDetailTab" />
        </Tab>
    </TabBar>

</Shell>
