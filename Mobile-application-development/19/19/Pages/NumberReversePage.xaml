<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="_19.Pages.NumberReversePage"
             Title="Число наоборот"
             BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray950}}">

    <Grid RowDefinitions="Auto,*" Padding="0">
        <Border Grid.Row="0" 
                BackgroundColor="{StaticResource Primary}"
                Padding="24,20"
                StrokeThickness="0">
            <VerticalStackLayout Spacing="6">
                <Label Text="🔢 Задание № 1" 
                       FontSize="28" FontAttributes="Bold" 
                       TextColor="White" />
                <Label Text="Получите число, записанное в обратном порядке" 
                       FontSize="14" TextColor="#E8E8E8" />
            </VerticalStackLayout>
        </Border>

        <ScrollView Grid.Row="1" Padding="20">
            <VerticalStackLayout Spacing="24" VerticalOptions="Center">
                <Border Stroke="{StaticResource Primary}"
                        StrokeThickness="2"
                        Padding="24"
                        BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}"
                        StrokeShape="RoundRectangle 20">
                    <Border.Shadow>
                        <Shadow Brush="{StaticResource Gray400}" Offset="0,6" Radius="16" Opacity="0.15" />
                    </Border.Shadow>
                    <VerticalStackLayout Spacing="16">
                        <Label Text="Введите число" 
                               FontSize="16" FontAttributes="Bold"
                               TextColor="{StaticResource Gray600}" />
                        <Entry x:Name="NumberEntry"
                               Placeholder="Например: 12345"
                               Keyboard="Numeric"
                               FontSize="20"
                               TextChanged="OnNumberTextChanged"
                               BackgroundColor="Transparent" />
                        <BoxView HeightRequest="1" Color="{StaticResource Gray300}" />
                        <Label Text="Результат:" 
                               FontSize="14" 
                               TextColor="{StaticResource Gray500}" />
                        <Border BackgroundColor="{StaticResource Secondary}"
                                Padding="20"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 12">
                            <Label x:Name="ResultLabel"
                                   Text="—"
                                   FontSize="32" FontAttributes="Bold"
                                   TextColor="{StaticResource Primary}"
                                   HorizontalTextAlignment="Center" />
                        </Border>
                        <Button Text="🔄 Перевернуть"
                                Clicked="OnReverseClicked"
                                BackgroundColor="{StaticResource Primary}"
                                TextColor="White"
                                FontSize="18" FontAttributes="Bold"
                                HeightRequest="52"
                                CornerRadius="12" />
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
